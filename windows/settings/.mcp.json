{
  "mcpServers": {
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@modelcontextprotocol/server-filesystem"
      ],
      "env": {}
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@modelcontextprotocol/server-memory"
      ],
      "env": {}
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {}
    },
    "fetch": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ],
      "env": {}
    },
    "git": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-git"
      ],
      "env": {}
    },
    "drawio": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@drawio/mcp"],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "env": {}
    },
    "browser": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@browsermcp/mcp@latest"],
      "env": {}
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": { "GITHUB_MCP_PAT": "${GITHUB_MCP_PAT}" }
    },
    "google_workspace": {
      "type": "stdio",
      "command": "uvx",
      "args": ["workspace-mcp"],
      "env": {
        "GOOGLE_OAUTH_CLIENT_ID": "${GW_CLIENT_ID}",
        "GOOGLE_OAUTH_CLIENT_SECRET": "${GW_CLIENT_SECRET}",
        "OAUTHLIB_INSECURE_TRANSPORT": "1"
      }
    },
    "todoist": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://ai.todoist.net/mcp"],
      "env": { "TODOIST_API_KEY": "${TODOIST_API_KEY}" }
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp",
      "env": {}
    },
    "huggingface": {
      "type": "http",
      "url": "https://huggingface.co/mcp?login",
      "env": {}
    },
    "perplexity": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@perplexity-ai/mcp-server"],
      "env": { "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}" }
    },
    "amazon-seller": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "amazon-sp-api-mcp-server"],
      "env": {}
    },
    "keepa": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "keepa-mcp-server"],
      "env": { "KEEPA_API_KEY": "${KEEPA_API_KEY}" }
    },
    "aws-iam": {
      "type": "stdio",
      "command": "uvx",
      "args": ["awslabs.iam-mcp-server@latest"],
      "env": {}
    },
    "google-maps": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@googlemaps/code-assist-mcp@latest"],
      "env": {}
    },
    "observability": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@google-cloud/observability-mcp"],
      "env": {}
    },
    "markitdown": {
      "type": "stdio",
      "command": "uvx",
      "args": ["markitdown-mcp"],
      "env": {}
    },
    "notebooklm-mcp": {
      "type": "stdio",
      "command": "notebooklm-mcp",
      "args": [],
      "env": {}
    },
    "openevidence": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "openevidence-mcp"],
      "env": {}
    },
    "desktop-commander": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@wonderwhy-er/desktop-commander"],
      "env": {}
    },
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "git+https://github.com/oraios/serena",
        "serena-mcp-server",
        "--port",
        "32123"
      ],
      "env": {}
    },
    "clasp": {
      "command": "npx",
      "args": ["-y", "@google/clasp", "mcp"]
    },
    "raindrop": {
      "type": "stdio",
      "command": "npx",
      "args": ["@adeze/raindrop-mcp@latest"],
      "env": {
        "RAINDROP_ACCESS_TOKEN": "${YOUR_RAINDROP_ACCESS_TOKEN}"
      }
    }
  }
}
