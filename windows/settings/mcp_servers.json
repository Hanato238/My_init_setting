{
  "mcpServers": {
    "perplexity": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@perplexity-ai/mcp-server"],
      "env": {
        "PERPLEXITY_API_KEY": "$PERPLEXITY_API_KEY"
      }
    },
    "fetch": {
      "type": "stdio",
      "command": "node",
      "args": ["%USERPROFILE%\\workspace\\mcp-servers\\mcp-official-servers\\src\\fetch\\dist\\index.js"],
      "env": {}
    },
    "sequentialthinking": {
      "type": "stdio",
      "command": "node",
      "args": ["%USERPROFILE%\\workspace\\mcp-servers\\mcp-official-servers\\src\\sequentialthinking\\dist\\index.js"],
      "env": {}
    },
    "drawio": {
      "type": "stdio",
      "command": "node",
      "args": ["%USERPROFILE%\\workspace\\mcp-servers\\drawio-mcp\\dist\\index.js"],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "@playwright/mcp@latest"],
      "env": {}
    },
    "desktop-commander": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@wonderwhy-er/desktop-commander@latest"],
      "env": {}
    },
    "browser-mcp": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "@agent-infra/mcp-server-browser@latest"
      ],
      "env": {}
    }
  }
}
